rules_version = '2';

// ═══════════════════════════════════════════════════════════════
//  REGLAS FIRESTORE — GloboBYM
//  Para aplicar: Firebase Console → Firestore Database → Reglas
//  → pegar este contenido → Publicar
//
//  Qué endurecen respecto a las reglas anteriores:
//  - El create público de pedidos ahora valida schema completo:
//    solo los campos permitidos, tipos correctos, longitudes máximas,
//    estado forzado a 'nuevo' y createdAt forzado al timestamp del
//    servidor. Un bot ya no puede insertar documentos arbitrarios
//    ni campos gigantes.
//  - Las métricas solo aceptan escrituras al documento 'general' y solo
//    sobre los campos conocidos del funnel (números), no campos arbitrarios.
//  - Leer, editar y borrar (datos de clientes) queda restringido SOLO
//    a la cuenta de admin por UID, no a cualquier usuario con sesión.
// ═══════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // Solo la cuenta del dueño (admin) puede leer/editar/borrar datos
    // de clientes. El UID sale de Firebase Console → Authentication → Users.
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'BeMfp5JFeubl2WlMmyEwzC8R49s1';
    }

    // ── PEDIDOS (cotizaciones del formulario público) ──
    match /pedidos/{id} {

      allow create: if
        // Solo los campos del formulario, nada más
        request.resource.data.keys().hasOnly([
          'nombre', 'telefono', 'tipo', 'pack', 'fecha',
          'distrito', 'mensaje', 'estado', 'createdAt', 'precioTotal'
        ]) &&
        // Campos obligatorios
        request.resource.data.keys().hasAll([
          'nombre', 'telefono', 'tipo', 'fecha', 'distrito', 'estado', 'createdAt'
        ]) &&
        // Tipos y longitudes
        request.resource.data.nombre is string &&
        request.resource.data.nombre.size() >= 2 &&
        request.resource.data.nombre.size() <= 100 &&
        request.resource.data.telefono is string &&
        request.resource.data.telefono.size() >= 6 &&
        request.resource.data.telefono.size() <= 25 &&
        request.resource.data.tipo is string &&
        request.resource.data.tipo.size() <= 60 &&
        request.resource.data.fecha is string &&
        request.resource.data.fecha.size() <= 20 &&
        request.resource.data.distrito is string &&
        request.resource.data.distrito.size() <= 60 &&
        // Opcionales (si vienen, deben ser válidos)
        (!('pack' in request.resource.data) ||
          (request.resource.data.pack is string && request.resource.data.pack.size() <= 40)) &&
        (!('mensaje' in request.resource.data) ||
          (request.resource.data.mensaje is string && request.resource.data.mensaje.size() <= 1500)) &&
        (!('precioTotal' in request.resource.data) ||
          (request.resource.data.precioTotal is number &&
           request.resource.data.precioTotal >= 0 &&
           request.resource.data.precioTotal <= 50000)) &&
        // Estado inicial forzado y timestamp del servidor
        request.resource.data.estado == 'nuevo' &&
        request.resource.data.createdAt == request.time;

      // Leer, editar y borrar: solo el panel (usuario autenticado)
      allow read, update, delete: if isAdmin();
    }

    // ── ÓRDENES DE LA TIENDA ONLINE ──
    match /ordenes_tienda/{id} {

      allow create: if
        request.resource.data.keys().hasOnly([
          'items', 'total', 'cliente', 'envio', 'notas', 'estado', 'createdAt'
        ]) &&
        request.resource.data.keys().hasAll([
          'items', 'total', 'cliente', 'envio', 'estado', 'createdAt'
        ]) &&
        // Items: lista no vacía y acotada
        request.resource.data.items is list &&
        request.resource.data.items.size() >= 1 &&
        request.resource.data.items.size() <= 30 &&
        // Total: número en rango razonable
        request.resource.data.total is number &&
        request.resource.data.total > 0 &&
        request.resource.data.total <= 50000 &&
        // Cliente
        request.resource.data.cliente is map &&
        request.resource.data.cliente.nombre is string &&
        request.resource.data.cliente.nombre.size() >= 2 &&
        request.resource.data.cliente.nombre.size() <= 100 &&
        request.resource.data.cliente.telefono is string &&
        request.resource.data.cliente.telefono.size() >= 6 &&
        request.resource.data.cliente.telefono.size() <= 25 &&
        // Envío
        request.resource.data.envio is map &&
        request.resource.data.envio.direccion is string &&
        request.resource.data.envio.direccion.size() >= 5 &&
        request.resource.data.envio.direccion.size() <= 200 &&
        request.resource.data.envio.distrito is string &&
        request.resource.data.envio.distrito.size() <= 60 &&
        request.resource.data.envio.fecha is string &&
        request.resource.data.envio.fecha.size() <= 20 &&
        request.resource.data.envio.rango is string &&
        request.resource.data.envio.rango.size() <= 40 &&
        // Notas opcionales
        (!('notas' in request.resource.data) ||
          (request.resource.data.notas is string && request.resource.data.notas.size() <= 500)) &&
        // Estado inicial forzado y timestamp del servidor
        request.resource.data.estado == 'nuevo' &&
        request.resource.data.createdAt == request.time;

      allow read, update, delete: if isAdmin();
    }

    // ── MÉTRICAS (contadores del sitio público) ──
    // El sitio incrementa visitas/orígenes/tiempo sin login, pero solo
    // sobre el documento 'general' y solo los campos conocidos del funnel.
    // Antes era `if true`: cualquiera podía sobrescribir el doc con basura
    // o blobs gigantes. Ahora la escritura solo puede tocar estos campos
    // y deben ser números (o mapa, en el caso de 'origenes').
    match /metricas/general {

      // Campos del funnel que el sitio público puede escribir.
      function camposMetricas() {
        return [
          'visitas_sitio', 'origenes', 'tiempo_total_segundos', 'tiempo_sesiones',
          'visitas_formulario', 'catalogo_aperturas', 'whatsapp_clicks',
          'tienda_visitas', 'carrito_agregados', 'checkout_inicios', 'ordenes_completadas'
        ];
      }

      // Cada contador, si viene en la escritura, debe ser número; 'origenes'
      // debe ser mapa. Evita meter un blob gigante en un campo válido.
      function tiposMetricasOk() {
        return (!('origenes'             in request.resource.data) || request.resource.data.origenes is map)
          && (!('visitas_sitio'          in request.resource.data) || request.resource.data.visitas_sitio is number)
          && (!('tiempo_total_segundos'  in request.resource.data) || request.resource.data.tiempo_total_segundos is number)
          && (!('tiempo_sesiones'        in request.resource.data) || request.resource.data.tiempo_sesiones is number)
          && (!('visitas_formulario'     in request.resource.data) || request.resource.data.visitas_formulario is number)
          && (!('catalogo_aperturas'     in request.resource.data) || request.resource.data.catalogo_aperturas is number)
          && (!('whatsapp_clicks'        in request.resource.data) || request.resource.data.whatsapp_clicks is number)
          && (!('tienda_visitas'         in request.resource.data) || request.resource.data.tienda_visitas is number)
          && (!('carrito_agregados'      in request.resource.data) || request.resource.data.carrito_agregados is number)
          && (!('checkout_inicios'       in request.resource.data) || request.resource.data.checkout_inicios is number)
          && (!('ordenes_completadas'    in request.resource.data) || request.resource.data.ordenes_completadas is number);
      }

      // Crear el doc por primera vez: solo campos conocidos y bien tipados.
      allow create: if request.resource.data.keys().hasOnly(camposMetricas())
                    && tiposMetricasOk();

      // Actualizar: la escritura solo puede TOCAR campos conocidos (diff sobre
      // las claves afectadas). Así no se rompe aunque el doc ya tuviera algún
      // campo viejo, pero impide añadir/modificar campos basura.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(camposMetricas())
                    && tiposMetricasOk();

      allow read: if isAdmin();
      allow delete: if false;
    }

    // Cualquier otra colección: bloqueada por defecto
  }
}
