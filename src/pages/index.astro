---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import dataProductos from '../data/productos.json';

// 3 productos para la vitrina de la tienda en la landing (destacados primero)
const vitrina = dataProductos.productos
  .filter((p) => p.disponible)
  .sort((a, b) => Number(b.destacado) - Number(a.destacado))
  .slice(0, 3);

const title = 'GloboBYM – Decoración con Globos a Domicilio en Lima, Perú';
const description = 'Boutique de globería profesional en Lima. Decoraciones personalizadas para cumpleaños, baby shower, bautizos, graduaciones, propuestas de matrimonio y eventos corporativos. +200 eventos realizados · 33K seguidores.';
---
<BaseLayout title={title} description={description}>
  <Fragment slot="head">
  <meta name="keywords" content="decoración con globos Lima, globería Lima, decoración cumpleaños Lima, baby shower Lima, decoración eventos Lima, arco de globos, globos personalizados Perú" />
  <meta name="author" content="GloboBYM" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href="https://globobym.netlify.app/" />
  <!-- Open Graph (Facebook, WhatsApp, LinkedIn) -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://globobym.netlify.app/" />
  <meta property="og:site_name" content="GloboBYM" />
  <meta property="og:locale" content="es_PE" />
  <meta property="og:title" content="GloboBYM – Decoración con Globos a Domicilio en Lima" />
  <meta property="og:description" content="Boutique de globería profesional en Lima. Decoraciones personalizadas para cumpleaños, baby shower y eventos. +200 eventos realizados." />
  <meta property="og:image" content="https://globobym.netlify.app/assets/foto1.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Decoración con globos profesional GloboBYM" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="GloboBYM – Decoración con Globos a Domicilio en Lima" />
  <meta name="twitter:description" content="Boutique de globería profesional en Lima. +200 eventos · 33K seguidores." />
  <meta name="twitter:image" content="https://globobym.netlify.app/assets/foto1.jpg" />

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://globobym.netlify.app/#business",
    "name": "GloboBYM",
    "alternateName": "GloboBYM Perú",
    "description": "Boutique de globería profesional en Lima, Perú. Decoraciones personalizadas para cumpleaños, baby shower, bautizos, graduaciones, propuestas de matrimonio y eventos corporativos. Servicio a domicilio.",
    "url": "https://globobym.netlify.app/",
    "image": "https://globobym.netlify.app/assets/foto1.jpg",
    "logo": "https://globobym.netlify.app/assets/logo.jpg",
    "telephone": "+51960876002",
    "priceRange": "S/ 650 – S/ 1,999",
    "areaServed": [
      { "@type": "City", "name": "Lima" },
      { "@type": "City", "name": "Callao" }
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Lima",
      "addressRegion": "Lima",
      "addressCountry": "PE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -12.0464,
      "longitude": -77.0428
    },
    "sameAs": [
      "https://www.instagram.com/globobym_peru/",
      "https://www.tiktok.com/@globobym_peru"
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5.0",
      "reviewCount": "200",
      "bestRating": "5"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Packs de decoración con globos",
      "itemListElement": [
        { "@type": "Offer", "name": "Pack 1", "price": "1999", "priceCurrency": "PEN" },
        { "@type": "Offer", "name": "Pack 2", "price": "1399", "priceCurrency": "PEN" },
        { "@type": "Offer", "name": "Pack 3", "price": "1099", "priceCurrency": "PEN" },
        { "@type": "Offer", "name": "Pack 4", "price": "799",  "priceCurrency": "PEN" },
        { "@type": "Offer", "name": "Pack 5", "price": "650",  "priceCurrency": "PEN" }
      ]
    }
  }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </Fragment>

  <Nav />

<!-- HERO -->
<section class="hero" id="inicio">
  <div class="hero-bg">
    <div class="hero-bg-slide active" style="background-image:url('assets/foto1.jpg')"></div>
    <div class="hero-bg-slide" style="background-image:url('assets/foto2.jpg')"></div>
    <div class="hero-bg-slide" style="background-image:url('assets/foto3.jpg')"></div>
    <div class="hero-bg-slide" style="background-image:url('assets/foto4.jpg')"></div>
    <div class="hero-bg-overlay"></div>
  </div>

  <div class="hero-text">
    <div class="hero-badge">Boutique de Globos · 33K seguidores · Lima, Perú</div>
    <h1 class="hero-title">
      Decoración con globos<br/><em>premium</em> a domicilio<br/>en Lima y Callao
    </h1>
    <p class="hero-bio">
      Somos <strong>GloboBYM</strong>, boutique de globería profesional.
      Diseñamos tu decoración a medida y la montamos en tu casa o local,
      con más de 33.000 personas que ya confían en nosotros.
    </p>
    <div class="hero-actions">
      <a href="#" class="btn-primary" id="btn-abrir-form-hero">📋 Solicitar cotización</a>
      <a href="#" class="btn-catalogo" id="btn-abrir-catalogo">📖 Ver packs y precios</a>
      <a href="#galeria" class="btn-secondary">Ver galería →</a>
    </div>
  </div>

  <!-- Decoraciones de esta semana (carousel dinámico — lee assets/semana/index.json) -->
  <aside class="semana-card" id="semanaCard" aria-label="Decoraciones de esta semana" hidden>
    <div class="semana-header">Decoraciones de esta semana</div>
    <div class="semana-sub">Lo más reciente</div>
    <div class="semana-slider" id="semanaSlider">
      <button type="button" class="semana-nav semana-prev" id="semanaPrev" aria-label="Anterior">‹</button>
      <button type="button" class="semana-nav semana-next" id="semanaNext" aria-label="Siguiente">›</button>
    </div>
    <div class="semana-dots" id="semanaDots"></div>
  </aside>

</section>

<!-- STATS STRIP -->
<div class="stats-strip">
  <div class="reveal">
    <span class="stat-item-num">33K</span>
    <div class="stat-item-label">Seguidores en Instagram</div>
  </div>
  <div class="reveal reveal-d1">
    <span class="stat-item-num">+5</span>
    <div class="stat-item-label">Años de experiencia</div>
  </div>
  <div class="reveal reveal-d2">
    <span class="stat-item-num">+500</span>
    <div class="stat-item-label">Eventos decorados</div>
  </div>
  <div class="reveal reveal-d3">
    <span class="stat-item-num">100%</span>
    <div class="stat-item-label">Hecho a medida</div>
  </div>
</div>

<!-- SERVICES -->
<section id="servicios">
  <div class="services-header">
    <div class="section-tag">Nuestros servicios</div>
    <h2 class="section-title">Todo lo que necesitas para<br/><em>tu evento perfecto</em></h2>
    <p class="section-sub">Diseñamos cada decoración desde cero, adaptada a tus colores, temática y presupuesto.</p>
  </div>
  <div class="services-grid">

    <div class="service-card reveal">
      <div class="service-icon">🎂</div>
      <h3>Cumpleaños Infantil</h3>
      <p>Decoraciones temáticas llenas de magia para que el cumpleaños de tu peque sea un recuerdo inolvidable.</p>
      <div class="service-tags"><span class="tag">Temático</span><span class="tag">Arco de globos</span><span class="tag">Personajes</span><span class="tag">Mesa dulce</span></div>
    </div>

    <div class="service-card reveal reveal-d1">
      <div class="service-icon">🥂</div>
      <h3>Cumpleaños Adulto</h3>
      <p>Decoraciones elegantes y sofisticadas para celebrar tu cumpleaños con el estilo que mereces.</p>
      <div class="service-tags"><span class="tag">Elegante</span><span class="tag">Backdrop</span><span class="tag">Dorado & Negro</span><span class="tag">Personalizado</span></div>
    </div>

    <div class="service-card reveal reveal-d2">
      <div class="service-icon">👶</div>
      <h3>Baby Shower</h3>
      <p>Celebra la llegada de tu bebé con una decoración llena de ternura y elegancia. Creamos ambientes únicos para este momento especial.</p>
      <div class="service-tags"><span class="tag">Niño / Niña</span><span class="tag">Pastel & Dorado</span><span class="tag">Globos orgánicos</span><span class="tag">Personalizado</span></div>
    </div>

    <div class="service-card reveal reveal-d3">
      <div class="service-icon">🏢</div>
      <h3>Corporativos</h3>
      <p>Decoraciones corporativas sofisticadas para lanzamientos, aniversarios, inauguraciones y celebraciones de empresa.</p>
      <div class="service-tags"><span class="tag">Branding</span><span class="tag">Corporativo</span><span class="tag">Lanzamientos</span><span class="tag">Aniversarios</span></div>
    </div>

    <div class="service-card reveal reveal-d4">
      <div class="service-icon">🎓</div>
      <h3>Graduaciones</h3>
      <p>Celebra el gran logro académico con una decoración que esté a la altura del esfuerzo. Elegante, emotiva y memorable.</p>
      <div class="service-tags"><span class="tag">Universitaria</span><span class="tag">Escolar</span><span class="tag">Toga & Birrete</span><span class="tag">Temático</span></div>
    </div>

    <div class="service-card reveal reveal-d5">
      <div class="service-icon">🕊️</div>
      <h3>Bautizos</h3>
      <p>Decora este momento sagrado con detalles tiernos y delicados que harán del bautizo un recuerdo eterno para toda la familia.</p>
      <div class="service-tags"><span class="tag">Niño / Niña</span><span class="tag">Pastel</span><span class="tag">Floral</span><span class="tag">Elegante</span></div>
    </div>

    <div class="service-card reveal reveal-d6">
      <div class="service-icon">🩷💙</div>
      <h3>Revelación de Sexo</h3>
      <p>El momento más esperado merece la mejor decoración. Creamos el ambiente perfecto para la gran revelación con globos sorpresa.</p>
      <div class="service-tags"><span class="tag">Gender Reveal</span><span class="tag">Niño / Niña</span><span class="tag">Globo sorpresa</span><span class="tag">Confeti</span></div>
    </div>

    <div class="service-card reveal reveal-d7">
      <div class="service-icon">💍</div>
      <h3>Propuestas de Matrimonio</h3>
      <p>Convierte el "¿te casas conmigo?" en un instante mágico e irrepetible. Decoraciones románticas para la propuesta perfecta.</p>
      <div class="service-tags"><span class="tag">Romántico</span><span class="tag">Sorpresa</span><span class="tag">Pétalos & Globos</span><span class="tag">Personalizado</span></div>
    </div>

  </div>
</section>

<!-- GALLERY -->
<section id="galeria">
  <div class="gallery-header">
    <div class="section-tag">Galería de trabajos</div>
    <h2 class="section-title">Nuestras creaciones<br/>hablan por sí solas</h2>
    <p class="section-sub">Cada decoración es única, hecha con amor y dedicación para hacer realidad tu visión. Haz clic para ver más fotos de cada categoría.</p>
  </div>

  <div class="gallery-grid">

    <div class="gallery-item reveal" data-slideshow>
      <span class="gallery-cat-badge">🎂 Cumpleaños Infantil</span>
      <img src="assets/cumpleanos-infantil/cumple1.jpg" class="slide active" alt="Cumpleaños Infantil" loading="lazy" />
      <img src="assets/cumpleanos-infantil/cumple4.jpg" class="slide" alt="Cumpleaños Infantil" loading="lazy" />
      <img src="assets/cumpleanos-infantil/cumple5.jpg" class="slide" alt="Cumpleaños Infantil" loading="lazy" />
      <div class="gallery-item-overlay"></div>
      <div class="gallery-expand" title="Ver foto completa">
        <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
      </div>
      <div class="slide-dots"></div>
      <div class="slide-hint">Clic para ver más →</div>
    </div>

    <div class="gallery-item reveal reveal-d1" data-slideshow>
      <span class="gallery-cat-badge">🥂 Cumpleaños Adulto</span>
      <img src="assets/cumpleanos-adulto/cumple2.jpg" class="slide active" alt="Cumpleaños Adulto" loading="lazy" />
      <img src="assets/cumpleanos-adulto/cumple3.jpg" class="slide" alt="Cumpleaños Adulto" loading="lazy" />
      <img src="assets/cumpleanos-adulto/cumple6.jpg" class="slide" alt="Cumpleaños Adulto" loading="lazy" />
      <div class="gallery-item-overlay"></div>
      <div class="gallery-expand" title="Ver foto completa">
        <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
      </div>
      <div class="slide-dots"></div>
      <div class="slide-hint">Clic para ver más →</div>
    </div>

    <div class="gallery-item reveal reveal-d2" data-slideshow>
      <span class="gallery-cat-badge">👶 Baby Shower</span>
      <img src="assets/baby-shower/foto2.jpg" class="slide active" alt="Baby Shower" loading="lazy" />
      <img src="assets/baby-shower/baby2.jpg" class="slide" alt="Baby Shower" loading="lazy" />
      <img src="assets/baby-shower/baby3.jpg" class="slide" alt="Baby Shower" loading="lazy" />
      <img src="assets/baby-shower/baby4.jpg" class="slide" alt="Baby Shower" loading="lazy" />
      <img src="assets/baby-shower/baby5.jpg" class="slide" alt="Baby Shower" loading="lazy" />
      <div class="gallery-item-overlay"></div>
      <div class="gallery-expand" title="Ver foto completa">
        <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
      </div>
      <div class="slide-dots"></div>
      <div class="slide-hint">Clic para ver más →</div>
    </div>

    <div class="gallery-item reveal reveal-d3" data-slideshow>
      <span class="gallery-cat-badge">💍 Propuesta de matrimonio</span>
      <img src="assets/propuesta-de-matrimonio/foto3.jpg" class="slide active" alt="Propuesta" loading="lazy" />
      <img src="assets/propuesta-de-matrimonio/propu2.jpg" class="slide" alt="Propuesta" loading="lazy" />
      <img src="assets/propuesta-de-matrimonio/propu3.jpg" class="slide" alt="Propuesta" loading="lazy" />
      <img src="assets/propuesta-de-matrimonio/propu4.jpg" class="slide" alt="Propuesta" loading="lazy" />
      <div class="gallery-item-overlay"></div>
      <div class="gallery-expand" title="Ver foto completa">
        <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
      </div>
      <div class="slide-dots"></div>
      <div class="slide-hint">Clic para ver más →</div>
    </div>

    <div class="gallery-item reveal reveal-d4" data-slideshow>
      <span class="gallery-cat-badge">🎓 Graduaciones</span>
      <img src="assets/graduaciones/graduacion1.jpg" class="slide active" alt="Graduaciones" loading="lazy" />
      <img src="assets/graduaciones/graduacion2.jpg" class="slide" alt="Graduaciones" loading="lazy" />
      <img src="assets/graduaciones/graduacion3.jpg" class="slide" alt="Graduaciones" loading="lazy" />
      <img src="assets/graduaciones/graduacion4.jpg" class="slide" alt="Graduaciones" loading="lazy" />
      <div class="gallery-item-overlay"></div>
      <div class="gallery-expand" title="Ver foto completa">
        <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
      </div>
      <div class="slide-dots"></div>
      <div class="slide-hint">Clic para ver más →</div>
    </div>

    <div class="gallery-item reveal reveal-d5" data-slideshow>
      <span class="gallery-cat-badge">🕊️ Bautizos</span>
      <img src="assets/bautizos/bautizo1.jpg" class="slide active" alt="Bautizos" loading="lazy" />
      <img src="assets/bautizos/bautizo2.jpg" class="slide" alt="Bautizos" loading="lazy" />
      <img src="assets/bautizos/bautizo3.jpg" class="slide" alt="Bautizos" loading="lazy" />
      <img src="assets/bautizos/bautizo4.jpg" class="slide" alt="Bautizos" loading="lazy" />
      <div class="gallery-item-overlay"></div>
      <div class="gallery-expand" title="Ver foto completa">
        <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
      </div>
      <div class="slide-dots"></div>
      <div class="slide-hint">Clic para ver más →</div>
    </div>

    <div class="gallery-item reveal reveal-d6" data-slideshow>
      <span class="gallery-cat-badge">🩷💙 Revelación de sexo</span>
      <img src="assets/revelacion-de-sexo/reve1.jpg" class="slide active" alt="Revelación de sexo" loading="lazy" />
      <img src="assets/revelacion-de-sexo/reve2.jpg" class="slide" alt="Revelación de sexo" loading="lazy" />
      <img src="assets/revelacion-de-sexo/reve3.jpg" class="slide" alt="Revelación de sexo" loading="lazy" />
      <div class="gallery-item-overlay"></div>
      <div class="gallery-expand" title="Ver foto completa">
        <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
      </div>
      <div class="slide-dots"></div>
      <div class="slide-hint">Clic para ver más →</div>
    </div>

    <div class="gallery-item coming-soon reveal reveal-d7">
      <span class="gallery-cat-badge">🏢 Corporativo</span>
      <div class="gallery-item-overlay"></div>
      <div class="slide-dots"></div>
      <div class="slide-hint">Clic para ver más →</div>
    </div>

  </div>

  </section>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true">
  <button class="lightbox-close" id="lightboxClose" aria-label="Cerrar">✕</button>
  <button class="lightbox-nav lightbox-prev" id="lightboxPrev" aria-label="Anterior">‹</button>
  <img src="" alt="" class="lightbox-img" id="lightboxImg" />
  <button class="lightbox-nav lightbox-next" id="lightboxNext" aria-label="Siguiente">›</button>
  <div class="lightbox-caption" id="lightboxCaption"></div>
</div>

<!-- CATÁLOGO MODAL -->
<div class="catalog-overlay" id="catalogOverlay" role="dialog" aria-modal="true" aria-label="Catálogo de packs">
  <div class="catalog-topbar">
    <div class="catalog-title">📖 Nuestro catálogo</div>
    <div class="catalog-actions">
      <button type="button" class="catalog-goto-galeria" id="catalogGotoGaleria">🖼️ Ir a la galería</button>
      <button type="button" class="catalog-close" id="catalogClose" aria-label="Cerrar catálogo">✕</button>
    </div>
  </div>
  <div class="catalog-grid">
    <img src="assets/catalogo/Pack1.jpeg" alt="Pack 1" loading="lazy" />
    <img src="assets/catalogo/Pack2.jpeg" alt="Pack 2" loading="lazy" />
    <img src="assets/catalogo/Pack3.jpeg" alt="Pack 3" loading="lazy" />
    <img src="assets/catalogo/Pack4.jpeg" alt="Pack 4" loading="lazy" />
    <img src="assets/catalogo/Pack5.jpeg" alt="Pack 5" loading="lazy" />
    <img src="assets/catalogo/Pack-economico.jpeg" alt="Pack Económico" loading="lazy" />
  </div>
</div>

<!-- TIENDA SHOWCASE -->
<section id="tienda-home">
  <div class="tienda-home-header">
    <div class="section-tag">🎁 Tienda GloboBYM</div>
    <h2 class="section-title">¿Necesitas un regalo <em>hoy</em>?</h2>
    <p class="section-sub">Globos personalizados, box sorpresa y ramos con delivery en Lima y Callao. Personalízalos con nombre y dedicatoria.</p>
  </div>
  <div class="tienda-home-grid">
    {vitrina.map((p) => (
      <a href={`/tienda/${p.id}/`} class="tienda-home-card reveal">
        <div class="tienda-home-img">
          {p.imagenes.length > 0
            ? <img src={`/assets/productos/${p.imagenes[0]}`} alt={p.nombre} loading="lazy" />
            : <div class="tienda-home-placeholder">🎈</div>
          }
        </div>
        <div class="tienda-home-info">
          <span class="tienda-home-nombre">{p.nombre}</span>
          <span class="tienda-home-precio">S/ {p.precio.toFixed(2)}</span>
        </div>
      </a>
    ))}
  </div>
  <div class="tienda-home-cta">
    <a href="/tienda/" class="btn-primary">🛍 Visitar la tienda →</a>
  </div>
</section>

<!-- WHY US -->
<section id="nosotros">
  <div class="why-grid">
    <div>
      <div class="section-tag">¿Por qué elegirnos?</div>
      <h2 class="section-title">Profesionalismo y<br/>pasión en cada<br/><em>detalle</em></h2>
      <p class="section-sub" style="margin-bottom:40px">Más de 5 años de experiencia nos respaldan. Cada proyecto lo tratamos como si fuera el nuestro.</p>
      <div class="why-features">
        <div class="feature reveal">
          <div class="feature-icon">🎯</div>
          <div><h4>Diseño personalizado</h4><p>Cada decoración se diseña desde cero según tu temática, colores y presupuesto. Nada genérico.</p></div>
        </div>
        <div class="feature reveal reveal-d1">
          <div class="feature-icon">⚡</div>
          <div><h4>Montaje puntual</h4><p>Llegamos a tiempo y dejamos todo listo antes de que lleguen tus invitados.</p></div>
        </div>
        <div class="feature reveal reveal-d2">
          <div class="feature-icon">💎</div>
          <div><h4>Materiales premium</h4><p>Usamos globos y materiales de alta calidad que lucen perfectos en fotos y duran toda la fiesta.</p></div>
        </div>
        <div class="feature reveal reveal-d3">
          <div class="feature-icon">📸</div>
          <div><h4>Fotos que enamoran</h4><p>Nuestras decoraciones están pensadas para que tus fotos y videos queden espectaculares.</p></div>
        </div>
      </div>
    </div>
