---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/admin.css';
---
<BaseLayout title="GloboBYM · Panel de Pedidos">
  <Fragment slot="head">
    <link rel="manifest" href="/manifest.json" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="GloboBYM" />
    <meta name="theme-color" content="#C2006B" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </Fragment>

<!-- ══ LOGIN SCREEN ══ -->
<div id="loginScreen" class="login-screen" hidden>
  <div class="login-card">
    <div class="login-logo">Globo<span>BYM</span></div>
    <div class="login-title">Panel de pedidos</div>
    <p class="login-sub">Accede con tu cuenta de administrador.</p>
    <form id="loginForm" autocomplete="on">
      <div class="form-group">
        <label for="loginEmail">Email</label>
        <input type="email" id="loginEmail" placeholder="tu@email.com" required autocomplete="email" />
      </div>
      <div class="form-group">
        <label for="loginPass">Contraseña</label>
        <input type="password" id="loginPass" placeholder="••••••••" required autocomplete="current-password" />
      </div>
      <button type="submit" class="btn-login" id="loginBtn">Entrar al panel</button>
    </form>
    <div class="login-error" id="loginError"></div>
  </div>
</div>

<!-- ══ DASHBOARD ══ -->
<div id="dashboard" hidden>

  <!-- Header -->
  <header class="app-header">
    <div class="header-logo">🎈 Globo<span>BYM</span></div>
    <div class="header-right">
      <span class="header-email" id="userEmail"></span>
      <button class="btn-logout" id="logoutBtn">Salir</button>
    </div>
  </header>

  <!-- Main nav -->
  <nav class="main-nav">
    <button class="main-nav-btn active" data-section="cotizaciones">📋 Cotizaciones</button>
    <button class="main-nav-btn" data-section="tienda">🛍 Tienda<span class="nav-badge" id="tiendaNavBadge" hidden>0</span></button>
    <button class="main-nav-btn" data-section="resumen">📊 Resumen</button>
    <button class="main-nav-btn" data-section="tracking">📈 Tracking</button>
  </nav>

  <!-- ══ SECCIÓN TIENDA (órdenes de la tienda online) ══ -->
  <div id="sectionTienda" hidden>
    <div class="stats-bar">
      <div class="stat-card s-nuevo">
        <div class="stat-num" id="tdStatNuevo">0</div>
        <div class="stat-label">🔴 Nuevas</div>
      </div>
      <div class="stat-card s-contactado">
        <div class="stat-num" id="tdStatPreparando">0</div>
        <div class="stat-label">📦 Preparando</div>
      </div>
      <div class="stat-card s-venta">
        <div class="stat-num" id="tdStatEnviado">0</div>
        <div class="stat-label">🚚 Enviadas</div>
      </div>
      <div class="stat-card s-atendido">
        <div class="stat-num" id="tdStatEntregado">0</div>
        <div class="stat-label">✅ Entregadas</div>
      </div>
      <div class="stat-card s-sin_compra">
        <div class="stat-num" id="tdStatCancelado">0</div>
        <div class="stat-label">✕ Canceladas</div>
      </div>
    </div>

    <div class="filter-bar">
      <div class="filter-tabs-row">
        <button class="tab active" data-tdfilter="todos">Todas</button>
        <button class="tab" data-tdfilter="nuevo">🔴 Nuevas</button>
        <button class="tab" data-tdfilter="preparando">📦 Preparando</button>
        <button class="tab" data-tdfilter="enviado">🚚 Enviadas</button>
        <button class="tab" data-tdfilter="entregado">✅ Entregadas</button>
        <button class="tab" data-tdfilter="cancelado">✕ Canceladas</button>
      </div>
    </div>

    <div class="orders-wrap">
      <div id="tiendaOrdersList">
        <div class="loading-wrap"><div class="spinner"></div></div>
      </div>
    </div>
  </div>

  <!-- ══ SECCIÓN COTIZACIONES ══ -->
  <div id="sectionCotizaciones">

    <div class="stats-bar">
      <div class="stat-card s-nuevo">
        <div class="stat-num" id="statNuevo">0</div>
        <div class="stat-label">🔴 Nuevos</div>
      </div>
      <div class="stat-card s-contactado">
        <div class="stat-num" id="statContactado">0</div>
        <div class="stat-label">🟡 Contactados</div>
      </div>
      <div class="stat-card s-venta">
        <div class="stat-num" id="statPagado">0</div>
        <div class="stat-label">🟣 Separados</div>
      </div>
      <div class="stat-card s-atendido">
        <div class="stat-num" id="statAtendido">0</div>
        <div class="stat-label">🟢 Atendidos</div>
      </div>
      <div class="stat-card s-venta">
        <div class="stat-num" id="statVenta">0</div>
        <div class="stat-label">💎 Ventas</div>
      </div>
      <div class="stat-card s-sin_compra">
        <div class="stat-num" id="statSinCompra">0</div>
        <div class="stat-label">⚪ Sin compra</div>
      </div>
    </div>

    <div class="filter-bar">
      <div class="filter-tabs-row">
        <button class="tab active" data-filter="todos">Todos</button>
        <button class="tab" data-filter="nuevo">🔴 Nuevos</button>
        <button class="tab" data-filter="contactado">🟡 Contactados</button>
        <button class="tab" data-filter="pagado">🟣 Separados</button>
        <button class="tab" data-filter="atendido">🟢 Atendidos</button>
        <button class="tab" data-filter="venta">💎 Ventas</button>
        <button class="tab" data-filter="sin_compra">⚪ Sin compra</button>
      </div>
      <div class="filter-bottom-row">
        <select class="filter-select" id="typeFilter">
          <option value="">Todos los eventos</option>
          <option>Cumpleaños Infantil</option>
          <option>Cumpleaños Adulto</option>
          <option>Baby Shower</option>
          <option>Corporativo</option>
          <option>Graduación</option>
          <option>Bautizo</option>
          <option>Revelación de Sexo</option>
          <option>Propuesta de Matrimonio</option>
          <option>Otro</option>
        </select>
        <span class="filter-count" id="filterCount"></span>
        <button class="btn-stats" id="btnStats">📊 Estadísticas</button>
      </div>
    </div>

    <div class="orders-wrap">
      <div id="ordersList">
        <div class="loading-wrap"><div class="spinner"></div></div>
      </div>
    </div>

  </div>

  <!-- ══ SECCIÓN RESUMEN ══ -->
  <div id="sectionResumen" hidden>
    <div class="tracking-wrap">
      <div class="tracking-title">Totales</div>
      <div class="metric-grid">
        <div class="metric-card">
          <div class="metric-num" id="rsmAtendidos">0</div>
          <div class="metric-label">✅ Pedidos atendidos</div>
          <div class="metric-sub">Servicios completados</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" id="rsmVentas">0</div>
          <div class="metric-label">💎 Ventas cerradas</div>
          <div class="metric-sub">Pedidos finalizados</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" id="rsmIngresos">S/ 0</div>
          <div class="metric-label">💰 Ingresos totales</div>
          <div class="metric-sub">Suma de precios cobrados</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" id="rsmSaldoPendiente">S/ 0</div>
          <div class="metric-label">⏳ Saldo pendiente</div>
          <div class="metric-sub">Por cobrar el día del evento</div>
        </div>
      </div>

      <div class="tracking-title" style="margin-top:28px">Buscar pedidos</div>
      <div class="resumen-filtros">
        <input type="text" id="rsmFilterNombre" placeholder="🔍 Nombre del cliente..." />
        <select id="rsmFilterEvento">
          <option value="">Todos los eventos</option>
          <option>Cumpleaños Infantil</option>
          <option>Cumpleaños Adulto</option>
          <option>Baby Shower</option>
          <option>Corporativo</option>
          <option>Graduación</option>
          <option>Bautizo</option>
          <option>Revelación de Sexo</option>
          <option>Propuesta de Matrimonio</option>
          <option>Otro</option>
        </select>
        <input type="month" id="rsmFilterMes" />
        <button class="btn-status" id="rsmFilterClear">Limpiar</button>
        <button class="btn-export" id="rsmExportBtn" title="Descargar resultados como archivo CSV (se abre en Excel)">📥 Exportar a Excel</button>
      </div>

      <div class="resumen-results-info" id="rsmResultsInfo"></div>
      <div id="rsmResultsList"></div>
    </div>
  </div>

  <!-- ══ SECCIÓN TRACKING ══ -->
  <div id="sectionTracking" hidden>
    <div class="tracking-wrap">

      <div class="tracking-title">Visitas al sitio</div>
      <div class="metric-grid">
        <div class="metric-card">
          <div class="metric-num" id="trVisitasSitio">—</div>
          <div class="metric-label">🌐 Visitas al sitio web</div>
          <div class="metric-sub">Personas que abrieron la página</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" id="trVisitas">—</div>
          <div class="metric-label">👁 Abrieron el formulario</div>
          <div class="metric-sub">De las visitas que vieron el form</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" id="trFormularios">0</div>
          <div class="metric-label">📋 Formularios enviados</div>
          <div class="metric-sub">Total de cotizaciones recibidas</div>
        </div>
        <div class="metric-card m-conversion">
          <div class="metric-num" id="trConversion">—</div>
          <div class="metric-label">🎯 Tasa de conversión</div>
          <div class="metric-sub">Visitas que enviaron formulario</div>
        </div>
        <div class="metric-card m-cierre">
          <div class="metric-num" id="trCierre">—</div>
          <div class="metric-label">💰 Tasa de cierre</div>
          <div class="metric-sub">Cotizaciones que se convirtieron en venta</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" id="trTiempoWeb">—</div>
          <div class="metric-label">⏱ Tiempo promedio en la web</div>
          <div class="metric-sub">Cuánto tiempo se quedan los visitantes</div>
        </div>
      </div>

      <div class="tracking-title">Embudo de conversión</div>
      <div class="funnel-card">
        <div class="funnel-step">
          <div class="funnel-label">🌐 Visitas al sitio</div>
          <div class="funnel-bar-wrap"><div class="funnel-bar" id="fbarSitio" style="width:100%;background:#6366f1"></div></div>
          <div class="funnel-count" id="fcntSitio">—</div>
          <div class="funnel-pct">100%</div>
        </div>
        <div class="funnel-step">
          <div class="funnel-label">📋 Formularios</div>
          <div class="funnel-bar-wrap"><div class="funnel-bar" id="fbarForm" style="width:0%;background:var(--contactado)"><span id="fbarFormLbl"></span></div></div>
          <div class="funnel-count" id="fcntForm">0</div>
          <div class="funnel-pct" id="fpctForm">—</div>
        </div>
        <div class="funnel-step">
          <div class="funnel-label">💎 Ventas</div>
          <div class="funnel-bar-wrap"><div class="funnel-bar" id="fbarVenta" style="width:0%;background:var(--venta)"><span></span></div></div>
          <div class="funnel-count" id="fcntVenta">0</div>
          <div class="funnel-pct" id="fpctVenta">—</div>
        </div>
      </div>

      <!-- OPERACIONES -->
      <div class="tracking-title" style="margin-top:28px">Operaciones</div>
      <div class="metric-grid">
        <div class="metric-card">
          <div class="metric-num" id="trRespuesta">—</div>
          <div class="metric-label">⏱ Tiempo de respuesta</div>
          <div class="metric-sub">Promedio de nuevo → contactado</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" id="trProximos">—</div>
          <div class="metric-label">📅 Eventos en 7 días</div>
          <div class="metric-sub">Pedidos pendientes de atender</div>
        </div>
      </div>
      <div id="upcomingList" class="upcoming-list"></div>

      <!-- DEMANDA -->
      <div class="tracking-title">Demanda</div>
      <div class="rank-grid">
        <div class="metric-card">
          <div class="metric-label">🎈 Tipo de evento</div>
          <div class="rank-list" id="tipoList"></div>
        </div>
        <div class="metric-card">
          <div class="metric-label">📆 Meses más activos</div>
          <div class="rank-list" id="mesList"></div>
        </div>
        <div class="metric-card">
          <div class="metric-label">📍 Top distritos</div>
          <div class="rank-list" id="distritoList"></div>
        </div>
        <div class="metric-card">
          <div class="metric-label">⏰ Hora pico de cotización</div>
          <div class="rank-list" id="horaList"></div>
        </div>
        <div class="metric-card">
          <div class="metric-label">🔗 Origen del tráfico</div>
          <div class="rank-list" id="origenList"></div>
        </div>
      </div>

      <!-- CLIENTES -->
      <div class="tracking-title">Clientes</div>
      <div class="metric-grid">
        <div class="metric-card">
          <div class="metric-num" id="trRecurrentes">—</div>
          <div class="metric-label">🔄 Clientes recurrentes</div>
          <div class="metric-sub">Han pedido 2 o más veces</div>
        </div>
        <div class="metric-card">
          <div class="metric-num" id="trUnicos">—</div>
          <div class="metric-label">👤 Clientes únicos</div>
          <div class="metric-sub">Teléfonos distintos registrados</div>
        </div>
      </div>

    </div>
  </div>

</div>

<!-- Stats modal -->
<div class="stats-modal-overlay" id="statsModal">
  <div class="stats-modal">
    <button class="stats-modal-close" id="statsModalClose">✕</button>
    <div class="stats-modal-title">📊 Pedidos por fecha</div>
    <div class="date-type-toggle">
      <button class="date-type-btn active" data-dtype="pedido">📦 Fecha de pedido</button>
      <button class="date-type-btn" data-dtype="evento">🎈 Fecha de evento</button>
    </div>
    <div class="period-tabs">
      <button class="period-tab active" data-period="dias">Últimos 7 días</button>
      <button class="period-tab" data-period="semanas">Últimas 4 semanas</button>
      <button class="period-tab" data-period="meses">Últimos 12 meses</button>
      <button class="period-tab" data-period="rango">Rango personalizado</button>
    </div>
    <div class="range-inputs" id="rangeInputs">
      <input type="date" id="rangeFrom" />
      <span style="color:var(--muted);font-size:.9rem">→</span>
      <input type="date" id="rangeTo" />
      <button class="tab active" style="padding:7px 16px;border-radius:8px" onclick="updateChart()">Aplicar</button>
    </div>
    <div class="chart-wrap">
      <canvas id="statsChart"></canvas>
    </div>
  </div>
</div>

<!-- Toast notification -->
<div class="toast" id="toast">
  <div class="toast-dot"></div>
  <span id="toastMsg">Nuevo pedido recibido</span>
</div>


  <!-- Chart.js + Firebase compat SDK + JS del panel -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script is:inline src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
  <script is:inline src="https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js"></script>
  <script is:inline src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>
  <script is:inline src="/js/admin.js"></script>
</BaseLayout>
